# Optional: public URL for canonical and Open Graph (e.g. https://yourdomain.com)
SITE_URL=

# Server (used by python main.py)
HOST=0.0.0.0
PORT=8000
RELOAD=true

# Email — Resend (https://resend.com, free tier: 3,000 emails/month)
# Leave blank to log submissions to console only (safe for local dev)
#
# NOTE: app/main.py sends from "onboarding@resend.dev" by default. Without a
# verified domain, Resend only delivers to YOUR account's own email address —
# emails to CONTACT_EMAIL below will fail with a 403 validation error.
# To send to any CONTACT_EMAIL, verify a domain at resend.com/domains and
# update the "from" address in app/main.py to use it.
RESEND_API_KEY=
CONTACT_EMAIL=hello@luminarystudio.com
